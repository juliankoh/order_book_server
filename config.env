# ─── Chain ────────────────────────────────────────────────
CHAIN="Mainnet"

# ─── Paths ────────────────────────────────────────────────
VISOR_BIN="$HOME/hl-visor"
NODE_DATA="$HOME/hl"
REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OB_SERVER_BIN="$REPO_DIR/target/release/websocket_server"
OB_SERVER_ADDRESS="0.0.0.0"
OB_SERVER_PORT=3002

# ─── NVMe ─────────────────────────────────────────────────
NVME_DEVICE="/dev/nvme1n1"
NVME_MOUNT="/mnt/hl-data"

# ─── Node flags ───────────────────────────────────────────
NODE_FLAGS="--write-raw-book-diffs --write-order-statuses --write-fills --stream-with-block-info --disable-output-file-buffering --serve-eth-rpc --serve-info"

# ─── Health thresholds ────────────────────────────────────
MAX_BLOCK_LAG=50
MAX_MEMORY_PCT=90
MAX_DISK_PCT=80
PRUNE_KEEP_MINUTES=180

# ─── Gossip ───────────────────────────────────────────────
GOSSIP_CONFIG="$HOME/override_gossip_config.json"
GOSSIP_UPDATE_INTERVAL=3600

# ─── Supervisor ───────────────────────────────────────────
HEALTH_CHECK_INTERVAL=10
OB_RESTART_DELAY=2
NODE_RESTART_DELAY=5

# ─── Tmux session names ──────────────────────────────────
TMUX_NODE="visor"
TMUX_OB="ob-server"
TMUX_SUPERVISOR="hl-supervisor"
